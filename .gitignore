# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts / local config (sensitive or machine-specific)
admin-panel.config.json
scripts/admin-panel.js
CLAUDE.md
AGENTS.md
.mcp.json

# supabase local files
supabase-rls-fix.sql
supabase-schema.sql
